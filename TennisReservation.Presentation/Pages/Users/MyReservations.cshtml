@page
@using TennisReservation.Domain.Enums
@model TennisReservation.Presentation.Pages.Users.MyReservationsModel
@{
    ViewData["Title"] = "Мои бронирования";
}

<style>
    .status-badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-booked {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .status-active {
        background: #dcfce7;
        color: #15803d;
    }

    .status-completed {
        background: #f3f4f6;
        color: #6b7280;
    }

    .status-cancelled {
        background: #fee2e2;
        color: #b91c1c;
    }
</style>

<div class="page-wrapper">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <span>✅ @TempData["SuccessMessage"]</span>
            <button class="close-btn" onclick="this.parentElement.remove()">×</button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error">
            <span>⚠️ @TempData["ErrorMessage"]</span>
            <button class="close-btn" onclick="this.parentElement.remove()">×</button>
        </div>
    }

    <div class="page-header">
        <h1><i class="fas fa-calendar-alt me-2"></i>Мои бронирования</h1>
        <div class="header-actions">
            <a asp-page="/Index" class="btn btn-outline">
                <i class="fas fa-home"></i> На главную
            </a>
            <a asp-area="TennisReservation.Presentation" asp-page="/Index" class="btn btn-primary">
                <i class="fas fa-plus"></i> Забронировать корт
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="fas fa-list me-2"></i>Список моих бронирований
        </div>

        @if (Model.Reservations.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Корт</th>
                        <th>Начало</th>
                        <th>Окончание</th>
                        <th>Стоимость</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Reservations)
                    {
                        <tr>
                            <td><strong>@r.CourtName</strong></td>
                            <td>@r.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@r.EndTime.ToString("dd.MM.yyyy HH:mm")</td>
                            <td><strong>@r.TotalCost.ToString("N0") ₽</strong></td>
                            <td>
                                @{
                                    var (cls, label) = r.Status switch
                                    {
                                        ReservationStatus.Booked => ("status-booked", "Забронировано"),
                                        ReservationStatus.Active => ("status-active", "Активно"),
                                        ReservationStatus.Completed => ("status-completed", "Завершено"),
                                        ReservationStatus.Cancelled => ("status-cancelled", "Отменено"),
                                        _ => ("status-completed", r.Status.ToString())
                                    };
                                }
                                <span class="status-badge @cls">@label</span>
                            </td>
                            <td>
                                <div class="actions">
                                    @if (r.Status == ReservationStatus.Booked)
                                    {
                                        <button class="btn btn-outline btn-sm" onclick="openModal('@r.Id')" title="Отменить">
                                            <i class="fas fa-ban"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @foreach (var r in Model.Reservations.Where(r => r.Status == ReservationStatus.Booked))
            {
                <div class="modal-overlay" id="modal-@r.Id">
                    <div class="modal-box">
                        <h5>Отмена бронирования</h5>
                        <p>Вы хотите отменить бронирование:</p>
                        <p class="name">@r.CourtName</p>
                        <p>@r.StartTime.ToString("dd.MM.yyyy HH:mm") — @r.EndTime.ToString("HH:mm")</p>
                        <p>Стоимость: <strong>@r.TotalCost.ToString("N0") ₽</strong></p>
                        <p class="warn">⚠️ Это действие нельзя отменить!</p>
                        <div class="modal-footer">
                            <button class="btn btn-outline" onclick="closeModal('@r.Id')">Назад</button>
                            <form method="post" asp-page-handler="Cancel" asp-route-id="@r.Id" style="margin:0">
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-times"></i> Отменить бронирование
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }

            <div class="card-footer">
                <span>Всего: <strong>@Model.Reservations.Count()</strong></span>
                <span>
                    Активных:
                    <strong>
                        @Model.Reservations.Count(r =>
                        r.Status == ReservationStatus.Booked ||
                        r.Status == ReservationStatus.Active)
                </strong>
            </span>
        </div>
                }
        else
        {
            <div class="empty-state">
                <i class="fas fa-calendar-alt"></i>
                <p>У вас пока нет бронирований</p>
                <a asp-page="/Reservations/Book" class="btn btn-primary" style="margin-top:12px;">
                    <i class="fas fa-plus"></i> Забронировать корт
                </a>
            </div>
        }
    </div>
</div>

<script>
    function openModal(id)  { document.getElementById('modal-' + id).classList.add('active'); }
    function closeModal(id) { document.getElementById('modal-' + id).classList.remove('active'); }

    document.querySelectorAll('.modal-overlay').forEach(el => {
        el.addEventListener('click', e => { if (e.target === el) el.classList.remove('active'); });
    });
</script>
