@page
@using TennisReservation.Domain.Models
@using TennisReservation.Presentation.Pages.Users
@model TennisReservation.Presentation.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Клиенты";
}

<div class="page-wrapper">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <span>✅ @TempData["SuccessMessage"]</span>
            <button class="close-btn" onclick="this.parentElement.remove()">×</button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error">
            <span>⚠️ @TempData["ErrorMessage"]</span>
            <button class="close-btn" onclick="this.parentElement.remove()">×</button>
        </div>
    }

    <div class="page-header">
        <h1><i class="fas fa-users me-2"></i>Клиенты</h1>
        <div class="header-actions">
            <a asp-page="/Index" class="btn btn-outline"><i class="fas fa-home"></i> На главную</a>
            <a asp-page="./Create" class="btn btn-primary"><i class="fas fa-plus"></i> Добавить клиента</a>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><i class="fas fa-list me-2"></i>Список клиентов</div>

        @if (Model.Users.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Имя</th>
                        <th>Фамилия</th>
                        <th>Email</th>
                        <th>Телефон</th>
                        <th>Дата регистрации</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.FirstName</td>
                            <td>@user.LastName</td>
                            <td>@user.Email</td>
                            <td>@user.PhoneNumber</td>
                            <td>@user.RegistrationDate.ToString("dd.MM.yyyy")</td>
                            <td>
                                <div class="actions">
                                    <a asp-page="./Edit" asp-route-id="@user.UserId" class="btn btn-outline btn-sm"><i class="fas fa-edit"></i></a>
                                    <a asp-page="./ManageCredentials" asp-route-id="@user.UserId" title="Управление доступом" class="btn btn-outline btn-sm">
                                        <i class="fas fa-key"></i>
                                    </a>
                                    <button class="btn btn-outline-danger btn-sm" onclick="openModal('modal-@user.UserId')"><i class="fas fa-trash"></i></button> 
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @foreach (var user in Model.Users)
            {
                <div class="modal-overlay" id="modal-@user.UserId">
                    <div class="modal-box">
                        <h5>Подтверждение удаления</h5>
                        <p>Вы хотите удалить клиента:</p>
                        <p class="name">@user.FirstName @user.LastName</p>
                        <p>@user.Email</p>
                        <p class="warn">⚠️ Это действие нельзя отменить!</p>
                        <div class="modal-footer">
                            <button class="btn btn-outline" onclick="closeModal('modal-@user.UserId')">Отмена</button>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@user.UserId" style="margin:0">
                                <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Удалить</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-users"></i>
                <h5>Клиенты не найдены</h5>
                <a asp-page="./Create" class="btn btn-primary">Добавить первого клиента</a>
            </div>
        }

        <div class="card-footer">
            Всего клиентов: <strong>@Model.Users.Count()</strong>
        </div>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id).classList.add('active'); }
    function closeModal(id) { document.getElementById(id).classList.remove('active'); }
    document.querySelectorAll('.modal-overlay').forEach(el => {
        el.addEventListener('click', e => { if (e.target === el) el.classList.remove('active'); });
    });
</script>
