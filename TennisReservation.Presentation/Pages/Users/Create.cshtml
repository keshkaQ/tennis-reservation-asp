@page
@using TennisReservation.Presentation.Pages.Users
@model TennisReservation.Presentation.Pages.Users.CreateModel
@{
    ViewData["Title"] = "Добавить пользователя";
}

<div class="page-wrapper" style="max-width:540px;margin:40px auto;padding:0 16px;">
    <div class="card">
        <div class="card-header">
            <h4><i class="fas fa-user-plus me-2"></i>Добавить нового пользователя</h4>
        </div>
        <div class="card-body">
            <div asp-validation-summary="ModelOnly" class="alert-error"></div>
            <form method="post" id="createForm">
                <div class="field-row">
                    <div class="field">
                        <label asp-for="ViewModel.FirstName">@Html.DisplayNameFor(model => model.ViewModel.FirstName)</label>
                        <input asp-for="ViewModel.FirstName" />
                        <span asp-validation-for="ViewModel.FirstName" class="text-danger"></span>
                    </div>
                    <div class="field">
                        <label asp-for="ViewModel.LastName">@Html.DisplayNameFor(model => model.ViewModel.LastName)</label>
                        <input asp-for="ViewModel.LastName" />
                        <span asp-validation-for="ViewModel.LastName" class="text-danger"></span>
                    </div>
                </div>
                <div class="field">
                    <label asp-for="ViewModel.Email">@Html.DisplayNameFor(model => model.ViewModel.Email)</label>
                    <input asp-for="ViewModel.Email" type="email" />
                    <span asp-validation-for="ViewModel.Email" class="text-danger"></span>
                </div>
                <div class="field">
                    <label asp-for="ViewModel.PhoneNumber">@Html.DisplayNameFor(model => model.ViewModel.PhoneNumber)</label>
                    <input asp-for="ViewModel.PhoneNumber" />
                    <span asp-validation-for="ViewModel.PhoneNumber" class="text-danger"></span>
                </div>
                <div class="field">
                    <label asp-for="ViewModel.Password">@Html.DisplayNameFor(model => model.ViewModel.Password)</label>
                    <input asp-for="ViewModel.Password" type="password" />
                    <span asp-validation-for="ViewModel.Password" class="text-danger"></span>
                </div>
            </form>
        </div>
        <div class="card-footer">
            <a asp-page="./Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Назад к списку</a>
            <button type="submit" form="createForm" class="btn btn-primary"><i class="fas fa-save"></i> Сохранить клиента</button>
        </div>
    </div>
</div>
