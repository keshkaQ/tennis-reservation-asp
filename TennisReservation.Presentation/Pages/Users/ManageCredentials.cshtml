@page "{id:guid}"
@using TennisReservation.Domain.Enums
@using TennisReservation.Presentation.Pages.Users
@model TennisReservation.Presentation.Pages.Users.ManageCredentialsModel
@{
    ViewData["Title"] = "Управление доступом";
    var isLocked = Model.UserInfo?.IsLocked() ?? false;
}

<style>
    .manage-wrapper {
        max-width: 540px;
        margin: 40px auto;
        padding: 0 16px;
    }

    .user-info-block {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 20px 24px;
        border-bottom: 2px solid #f0f0f0;
    }

    .user-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #1e4b3c;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .user-name {
        font-weight: 700;
        font-size: 1.05rem;
        color: #333;
    }

    .user-email {
        color: #888;
        font-size: 0.85rem;
        margin-top: 2px;
    }

    .status-badge-active {
        background: #dcfce7;
        color: #15803d;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-badge-locked {
        background: #fee2e2;
        color: #b91c1c;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .section {
        padding: 22px 24px;
        border-bottom: 2px solid #f0f0f0;
    }

    .section-title {
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #1e4b3c;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .inline-row {
        display: flex;
        align-items: flex-end;
        gap: 12px;
    }

        .inline-row .field {
            flex: 1;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .inline-row .btn {
            margin-bottom: 8px;
            white-space: nowrap;
        }

    .lock-info {
        background: #fff5f5;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: 12px 16px;
        color: #b91c1c;
        font-size: 0.88rem;
        font-weight: 500;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .stats-row {
        display: flex;
        gap: 24px;
        padding: 14px 24px;
        background: #f8f9fa;
        border-top: 1px solid #eee;
        font-size: 0.83rem;
        color: #666;
    }

        .stats-row strong {
            color: #333;
        }
</style>

<div class="manage-wrapper">

    <div class="back">
        <a asp-page="./Index"><i class="fas fa-arrow-left"></i> Назад к списку</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <span>&#x2705; @TempData["SuccessMessage"]</span>
            <button class="close-btn" onclick="this.parentElement.remove()">x</button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error">
            <span>@TempData["ErrorMessage"]</span>
            <button class="close-btn" onclick="this.parentElement.remove()">x</button>
        </div>
    }

    <div class="card">
        <div class="card-header">
            <h4><i class="fas fa-key me-2"></i>Управление доступом</h4>
        </div>

        <div class="user-info-block">
            <div class="user-avatar">
                @(Model.UserInfo?.User?.FirstName?.FirstOrDefault())
            </div>
            <div>
                <div class="user-name">@Model.UserInfo?.User?.FirstName @Model.UserInfo?.User?.LastName</div>
                <div class="user-email">@Model.UserInfo?.User?.Email</div>
            </div>
            <div style="margin-left:auto;">
                @if (isLocked)
                {
                    <span class="status-badge-locked"><i class="fas fa-lock me-1"></i>Заблокирован</span>
                }
                else
                {
                    <span class="status-badge-active"><i class="fas fa-check me-1"></i>Активен</span>
                }
            </div>
        </div>

        <div class="section">
            <div class="section-title"><i class="fas fa-user-shield"></i> Роль пользователя</div>
            <form method="post" asp-page-handler="ChangeRole">
                <input type="hidden" name="ViewModel.UserId" value="@Model.ViewModel.UserId" />
                <div class="inline-row">
                    <div class="field">
                        <select name="ViewModel.Role">
                            <option value="@((int)UserRole.User)" selected="@(Model.UserInfo?.Role == UserRole.User)">Пользователь</option>
                            <option value="@((int)UserRole.Admin)" selected="@(Model.UserInfo?.Role == UserRole.Admin)">Администратор</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Сохранить
                    </button>
                </div>
            </form>
        </div>

        <div class="section">
            <div class="section-title"><i class="fas fa-lock"></i> Смена пароля</div>
            <form method="post" asp-page-handler="ChangePassword">
                <input type="hidden" name="ViewModel.UserId" value="@Model.ViewModel.UserId" />
                <div class="field-row">
                    <div class="field">
                        <label>Новый пароль</label>
                        <input type="password" name="ViewModel.NewPassword" placeholder="Новый пароль" />
                    </div>
                    <div class="field">
                        <label>Подтверждение</label>
                        <input type="password" name="ViewModel.ConfirmPassword" placeholder="Повторите пароль" />
                    </div>
                </div>
                <div style="display:flex;justify-content:flex-end;">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Сменить пароль
                    </button>
                </div>
            </form>
        </div>

        <div class="section">
            <div class="section-title"><i class="fas fa-ban"></i> Блокировка</div>
            @if (isLocked)
            {
                <div class="lock-info">
                    <i class="fas fa-lock"></i>
                    Заблокирован до @Model.UserInfo?.LockedUntil?.ToString("dd.MM.yyyy HH:mm")
                </div>
                <form method="post" asp-page-handler="Unlock">
                    <input type="hidden" name="ViewModel.UserId" value="@Model.ViewModel.UserId" />
                    <button type="submit" class="btn btn-outline">
                        <i class="fas fa-lock-open me-1"></i>Снять блокировку
                    </button>
                </form>
            }
            else
            {
                <form method="post" asp-page-handler="Lock">
                    <input type="hidden" name="ViewModel.UserId" value="@Model.ViewModel.UserId" />
                    <div class="inline-row">
                        <div class="field">
                            <label>Заблокировать до</label>
                            <input type="datetime-local" name="ViewModel.LockUntil"
                                   min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                        </div>
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-ban me-1"></i>Заблокировать
                        </button>
                    </div>
                </form>
            }
        </div>

        @if (Model.UserInfo != null)
        {
            <div class="stats-row">
                <span>
                    <i class="fas fa-exclamation-circle me-1" style="color:#f59e0b;"></i>
                    Неудачных попыток: <strong>@Model.UserInfo.FailedLoginAttempts</strong>
                </span>
                <span>
                    <i class="fas fa-sign-in-alt me-1" style="color:#1e4b3c;"></i>
                    Последний вход: <strong>@(Model.UserInfo.LastLoginAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</strong>
                </span>
            </div>
        }

    </div>
</div>
