@page
@using TennisReservation.Presentation.Pages.TennisCourts.ViewModels
@model TennisReservation.Presentation.Pages.TennisCourts.CreateModel
@{
    ViewData["Title"] = "Добавить корт";
}

<div class="page-wrapper" style="max-width:540px;margin:40px auto;padding:0 16px;">
    <div class="card">
        <div class="card-header">
            <h4><i class="fas fa-plus me-2"></i>Добавление новой площадки</h4>
        </div>
        <div class="card-body">
            <div asp-validation-summary="ModelOnly" class="alert-error"></div>
            <form method="post" id="createForm">
                <div class="field">
                    <label asp-for="ViewModel.Name">@Html.DisplayNameFor(model => model.ViewModel.Name)</label>
                    <input asp-for="ViewModel.Name" placeholder="Введите название корта" />
                    <span asp-validation-for="ViewModel.Name" class="text-danger"></span>
                    <div class="field-hint">Минимум 3 символа, только буквы, цифры и пробелы</div>
                </div>
                <div class="field">
                    <label asp-for="ViewModel.HourlyRate">@Html.DisplayNameFor(model => model.ViewModel.HourlyRate)</label>
                    <div class="input-with-suffix">
                        <input asp-for="ViewModel.HourlyRate" type="number" min="100" max="10000" step="100" placeholder="1000" />
                        <span class="input-suffix">₽/час</span>
                    </div>
                    <span asp-validation-for="ViewModel.HourlyRate" class="text-danger"></span>
                    <div class="field-hint">От 100 до 10000 ₽ в час</div>
                </div>
                <div class="field">
                    <label asp-for="ViewModel.Description">@Html.DisplayNameFor(model => model.ViewModel.Description)</label>
                    <textarea asp-for="ViewModel.Description" rows="4" placeholder="Введите описание корта (необязательно)"></textarea>
                    <span asp-validation-for="ViewModel.Description" class="text-danger"></span>
                    <div class="field-hint">Максимум 500 символов</div>
                </div>
            </form>
        </div>
        <div class="card-footer">
            <a asp-page="./Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Назад к списку</a>
            <button type="submit" form="createForm" class="btn btn-primary"><i class="fas fa-save"></i> Сохранить корт</button>
        </div>
    </div>
</div>
