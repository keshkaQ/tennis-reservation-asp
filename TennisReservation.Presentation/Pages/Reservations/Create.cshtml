@page
@using TennisReservation.Domain.Enums
@using TennisReservation.Domain.Models
@using TennisReservation.Presentation.Pages.Reservations
@model TennisReservation.Presentation.Pages.Reservations.CreateModel
@{
    ViewData["Title"] = "Новое бронирование";
    var today = DateTime.Today;
}

<style>
.wrapper {
    max-width: 480px;
    margin: 30px auto;
    background: white;
    padding: 25px;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
}
.btn {
    width: 100%;
    padding: 15px;
    justify-content: center;
    font-size: 1.1rem;
}
</style>

<div class="container" style="padding: 30px 16px;">
    <div class="wrapper">
        <div class="back">
            <a asp-page="./Index"><i class="fas fa-arrow-left"></i> Назад к списку бронирований</a>
        </div>

        <div class="page-title">
            <i class="fas fa-calendar-plus me-2"></i>Новое бронирование
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">⚠️ @TempData["Error"]</div>
        }
        <form method="post" id="bookingForm">
            @Html.AntiForgeryToken()

            <div class="field">
                <label><i class="fas fa-tennis-ball me-2"></i>Корт</label>
                <select asp-for="ViewModel.TennisCourtId" id="courtSelect" required>
                    <option value="">— выберите корт —</option>
                    @foreach (var court in Model.TennisCourts)
                    {
                        <option value="@court.Id" data-price="@court.HourlyRate">@court.Name — @court.HourlyRate ₽/час</option>
                    }
                </select>
                <span asp-validation-for="ViewModel.TennisCourtId" class="text-danger"></span>
            </div>

            <div class="field">
                <label><i class="fas fa-user me-2"></i>Клиент</label>
                <select asp-for="ViewModel.UserId" id="userSelect" required>
                    <option value="">— выберите клиента —</option>
                    @foreach (var user in Model.Users)
                    {
                        <option value="@user.UserId">@user.LastName @user.FirstName</option>
                    }
                </select>
                <span asp-validation-for="ViewModel.UserId" class="text-danger"></span>
            </div>

            <div class="field">
                <label><i class="fas fa-calendar-alt me-2"></i>Дата</label>
                <input type="date" asp-for="ViewModel.Date" id="date"
                       value="@today.ToString("yyyy-MM-dd")"
                       min="@today.ToString("yyyy-MM-dd")"
                       max="@DateTime.Today.AddDays(30).ToString("yyyy-MM-dd")"
                       required />
            </div>

            <div class="field-row">
                <div class="field">
                    <label><i class="fas fa-clock me-2"></i>Время начала</label>
                    <select asp-for="ViewModel.StartTime" id="startTime" required>
                        <option value="">Выберите время</option>
                        @for (int hour = 8; hour <= 21; hour++)
                        {
                            <option value="@hour:00">@hour:00</option>
                            if (hour < 21)
                            {
                                <option value="@hour:30">@hour:30</option>
                            }
                        }
                    </select>
                    <div class="time-end" id="timeEnd"></div>
                </div>
                <div class="field">
                    <label><i class="fas fa-hourglass-half me-2"></i>Длительность</label>
                    <select asp-for="ViewModel.Duration" id="duration" required>
                        <option value="1">1 час</option>
                        <option value="1.5">1.5 часа</option>
                        <option value="2">2 часа</option>
                        <option value="2.5">2.5 часа</option>
                        <option value="3">3 часа</option>
                    </select>
                </div>
            </div>

            <div class="total">
                <div class="label">ИТОГОВАЯ СТОИМОСТЬ</div>
                <div class="value" id="totalPrice">— ₽</div>
                <div class="details" id="priceDetails">Выберите корт и время</div>
            </div>

            <button type="submit" class="btn btn-primary" id="submitBtn" disabled>
                <i class="fas fa-save me-2"></i>Сохранить бронирование
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const courtSelect = document.getElementById('courtSelect');
        const startSelect = document.getElementById('startTime');
        const durationSelect = document.getElementById('duration');
        const dateInput = document.getElementById('date');
        const totalEl = document.getElementById('totalPrice');
        const detailsEl = document.getElementById('priceDetails');
        const timeEndEl = document.getElementById('timeEnd');
        const submitBtn = document.getElementById('submitBtn');

        const durationLabels = { '1': '1 час', '1.5': '1.5 часа', '2': '2 часа', '2.5': '2.5 часа', '3': '3 часа' };

        function addMinutes(timeStr, minutes) {
            const [h, m] = timeStr.split(':').map(Number);
            const total = h * 60 + m + minutes;
            return `${Math.floor(total / 60)}:${String(total % 60).padStart(2, '0')}`;
        }

        function update() {
            const opt = courtSelect.options[courtSelect.selectedIndex];
            const rate = opt && courtSelect.value ? parseFloat(opt.dataset.price) : 0;
            const duration = parseFloat(durationSelect.value);
            const hasAll = courtSelect.value && startSelect.value && dateInput.value;

            if (!hasAll || !rate) {
                totalEl.textContent = '— ₽';
                detailsEl.textContent = 'Выберите корт и время';
                timeEndEl.textContent = '';
                submitBtn.disabled = true;
                return;
            }

            totalEl.classList.add('updating');
            setTimeout(() => {
                totalEl.textContent = Math.round(rate * duration).toLocaleString('ru-RU') + ' ₽';
                totalEl.classList.remove('updating');
            }, 150);

            detailsEl.textContent = `${durationLabels[durationSelect.value] || duration + ' ч'} × ${rate} ₽/час`;
            timeEndEl.textContent = `→ окончание в ${addMinutes(startSelect.value, duration * 60)}`;
            submitBtn.disabled = false;
        }

        [courtSelect, startSelect, durationSelect, dateInput].forEach(el => el.addEventListener('change', update));
        update();
    </script>
}

