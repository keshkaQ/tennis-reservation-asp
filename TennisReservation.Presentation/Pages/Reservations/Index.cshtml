@page
@using TennisReservation.Domain.Enums
@using TennisReservation.Presentation.Pages.Reservations
@model TennisReservation.Presentation.Pages.Reservations.IndexModel
@{
    ViewData["Title"] = "Бронирования";
}

<style>
    .page-wrapper {
        max-width: 1100px;
    }

    .status-badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-booked {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .status-active {
        background: #dcfce7;
        color: #15803d;
    }

    .status-completed {
        background: #f3f4f6;
        color: #6b7280;
    }

    .status-cancelled {
        background: #fee2e2;
        color: #b91c1c;
    }

    thead a {
        color: inherit;
        text-decoration: none;
        white-space: nowrap;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

        thead a:hover {
            text-decoration: underline;
            opacity: 0.8;
        }

    .filter-tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 16px;
        flex-wrap: wrap;
        align-items: center;
    }

    .filter-tab {
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        border: 2px solid transparent;
        transition: all 0.15s;
        color: #374151;
        background: #f3f4f6;
    }

        .filter-tab:hover {
            background: #e5e7eb;
            text-decoration: none;
            color: #111;
        }

        .filter-tab.active-tab {
            background: #1d4ed8;
            color: #fff;
            border-color: #1d4ed8;
        }

        .filter-tab.tab-active {
            background: #dcfce7;
            color: #15803d;
            border-color: #15803d;
        }

            .filter-tab.tab-active.active-tab {
                background: #15803d;
                color: #fff;
            }
</style>

<div class="page-wrapper">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <span>✅ @TempData["SuccessMessage"]</span>
            <button class="close-btn" onclick="this.parentElement.remove()">×</button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-error">
            <span>⚠️ @TempData["ErrorMessage"]</span>
            <button class="close-btn" onclick="this.parentElement.remove()">×</button>
        </div>
    }

    <div class="page-header">
        <h1><i class="fas fa-calendar-alt me-2"></i>Бронирования</h1>
        <div class="header-actions">
            <a asp-page="/Index" class="btn btn-outline"><i class="fas fa-home"></i> На главную</a>
            <a asp-page="./Create" class="btn btn-primary"><i class="fas fa-plus"></i> Новое бронирование</a>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><i class="fas fa-list me-2"></i>Список бронирований</div>

        <div style="padding: 12px 16px 0;">
            <div class="filter-tabs">
                <a asp-page="./Index"
                   asp-route-statusFilter="All"
                   asp-route-sortField="@Model.SortField"
                   asp-route-sortAsc="@Model.SortAsc.ToString().ToLower()"
                   class="filter-tab @(Model.StatusFilter == "All" ? "active-tab" : "")">
                    Все
                </a>
                <a asp-page="./Index"
                   asp-route-statusFilter="Active"
                   asp-route-sortField="@Model.SortField"
                   asp-route-sortAsc="@Model.SortAsc.ToString().ToLower()"
                   class="filter-tab tab-active @(Model.StatusFilter == "Active" ? "active-tab" : "")">
                    <i class="fas fa-bolt" style="font-size:0.75rem"></i> Активные
                </a>
                <a asp-page="./Index"
                   asp-route-statusFilter="Completed"
                   asp-route-sortField="@Model.SortField"
                   asp-route-sortAsc="@Model.SortAsc.ToString().ToLower()"
                   class="filter-tab @(Model.StatusFilter == "Completed" ? "active-tab" : "")"
                   style="background:#f3f4f6; color:#6b7280; border-color: @(Model.StatusFilter == "Completed" ? "#6b7280" : "transparent")">
                    Завершённые
                </a>
                <a asp-page="./Index"
                   asp-route-statusFilter="Cancelled"
                   asp-route-sortField="@Model.SortField"
                   asp-route-sortAsc="@Model.SortAsc.ToString().ToLower()"
                   class="filter-tab @(Model.StatusFilter == "Cancelled" ? "active-tab" : "")"
                   style="@(Model.StatusFilter == "Cancelled" ? "background:#b91c1c; color:#fff; border-color:#b91c1c;" : "background:#fee2e2; color:#b91c1c; border-color:transparent;")">
                    Отменённые
                </a>
            </div>
        </div>

        @if (Model.Reservations.Any())
        {
            <table>
                <thead>
                    <tr>
                        <th>Клиент</th>
                        <th>
                            <a asp-page="./Index"
                               asp-route-sortField="CourtName"
                               asp-route-sortAsc="@(Model.SortField == "CourtName" ? (!Model.SortAsc).ToString().ToLower() : "true")"
                               asp-route-statusFilter="@Model.StatusFilter">
                                Корт
                                @if (Model.SortField == "CourtName")
                                {
                                    <span>@(Model.SortAsc ? "▲" : "▼")</span>
                                }
                                else
                                {

                                    <span style="opacity:0.4">⇅</span>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-page="./Index"
                               asp-route-sortField="StartTime"
                               asp-route-sortAsc="@(Model.SortField == "StartTime" ? (!Model.SortAsc).ToString().ToLower() : "true")"
                               asp-route-statusFilter="@Model.StatusFilter">
                                Начало
                                @if (Model.SortField == "StartTime")
                                {
                                    <span>@(Model.SortAsc ? "▲" : "▼")</span>
                                }
                                else
                                {

                                    <span style="opacity:0.4">⇅</span>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-page="./Index"
                               asp-route-sortField="EndTime"
                               asp-route-sortAsc="@(Model.SortField == "EndTime" ? (!Model.SortAsc).ToString().ToLower() : "true")"
                               asp-route-statusFilter="@Model.StatusFilter">
                                Окончание
                                @if (Model.SortField == "EndTime")
                                {
                                    <span>@(Model.SortAsc ? "▲" : "▼")</span>
                                }
                                else
                                {

                                    <span style="opacity:0.4">⇅</span>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-page="./Index"
                               asp-route-sortField="TotalCost"
                               asp-route-sortAsc="@(Model.SortField == "TotalCost" ? (!Model.SortAsc).ToString().ToLower() : "true")"
                               asp-route-statusFilter="@Model.StatusFilter">
                                Стоимость
                                @if (Model.SortField == "TotalCost")
                                {
                                    <span>@(Model.SortAsc ? "▲" : "▼")</span>
                                }
                                else
                                {

                                    <span style="opacity:0.4">⇅</span>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-page="./Index"
                               asp-route-sortField="Status"
                               asp-route-sortAsc="@(Model.SortField == "Status" ? (!Model.SortAsc).ToString().ToLower() : "true")"
                               asp-route-statusFilter="@Model.StatusFilter">
                                Статус
                                @if (Model.SortField == "Status")
                                {
                                    <span>@(Model.SortAsc ? "▲" : "▼")</span>
                                }
                                else
                                {

                                    <span style="opacity:0.4">⇅</span>
                                }
                            </a>
                        </th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Reservations)
                    {
                        <tr>
                            <td>@r.UserFirstName @r.UserLastName</td>
                            <td>@r.CourtName</td>
                            <td>@r.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@r.EndTime.ToString("dd.MM.yyyy HH:mm")</td>
                            <td><strong>@r.TotalCost.ToString("N0") ₽</strong></td>
                            <td>
                                @{
                                    var (cls, txt) = r.Status switch
                                    {
                                        ReservationStatus.Booked => ("status-booked", "Забронировано"),
                                        ReservationStatus.Active => ("status-active", "Активно"),
                                        ReservationStatus.Completed => ("status-completed", "Завершено"),
                                        ReservationStatus.Cancelled => ("status-cancelled", "Отменено"),
                                        _ => ("status-completed", r.Status.ToString())
                                    };
                                }
                                <span class="status-badge @cls">@txt</span>
                            </td>
                            <td>
                                <div class="actions">
                                    <a asp-page="./Edit" asp-route-id="@r.Id" class="btn btn-outline btn-sm">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    @if (r.Status != ReservationStatus.Cancelled && r.Status != ReservationStatus.Completed)
                                    {
                                        <button class="btn btn-outline btn-sm" onclick="openModal('cancel-@r.Id')" title="Отменить">
                                            <i class="fas fa-ban"></i>
                                        </button>
                                    }
                                    <button class="btn btn-outline-danger btn-sm" onclick="openModal('modal-@r.Id')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @foreach (var r in Model.Reservations)
            {
                <div class="modal-overlay" id="modal-@r.Id">
                    <div class="modal-box">
                        <h5>Подтверждение удаления</h5>
                        <p>Вы хотите удалить бронирование:</p>
                        <p class="name">@r.UserFirstName @r.UserLastName</p>
                        <p>@r.StartTime.ToString("dd.MM.yyyy HH:mm") — @r.EndTime.ToString("HH:mm")</p>
                        <p>Стоимость: @r.TotalCost.ToString("N0") ₽</p>
                        <p class="warn">⚠️ Это действие нельзя отменить!</p>
                        <div class="modal-footer">
                            <button class="btn btn-outline" onclick="closeModal('modal-@r.Id')">Отмена</button>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@r.Id" style="margin:0">
                                <button type="submit" class="btn btn-danger"><i class="fas fa-trash"></i> Удалить</button>
                            </form>
                        </div>
                    </div>
                </div>

                @if (r.Status != ReservationStatus.Cancelled && r.Status != ReservationStatus.Completed)
                {
                    <div class="modal-overlay" id="cancel-@r.Id">
                        <div class="modal-box">
                            <h5>Подтверждение отмены</h5>
                            <p>Вы хотите отменить бронирование:</p>
                            <p class="name">@r.UserFirstName @r.UserLastName</p>
                            <p>@r.StartTime.ToString("dd.MM.yyyy HH:mm") — @r.EndTime.ToString("HH:mm")</p>
                            <p>Стоимость: @r.TotalCost.ToString("N0") ₽</p>
                            <div class="modal-footer">
                                <button class="btn btn-outline" onclick="closeModal('cancel-@r.Id')">Закрыть</button>
                                <form method="post" asp-page-handler="Cancel" asp-route-id="@r.Id" style="margin:0">
                                    <button type="submit" class="btn btn-danger">
                                        <i class="fas fa-ban"></i> Отменить бронирование
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-calendar-alt"></i>
                <h5>Бронирования не найдены</h5>
                @if (Model.StatusFilter != "All")
                {
                    <p style="color:#6b7280; font-size:0.9rem;">Попробуйте выбрать другой фильтр</p>
                }
                else
                {
                    <a asp-page="./Create" class="btn btn-primary" style="margin-top:12px;"><i class="fas fa-plus"></i> Создать первое бронирование</a>
                }
            </div>
        }

        <div class="card-footer">
            <span>Показано: <strong>@Model.Reservations.Count()</strong></span>
            <span>Сумма: <strong>@Model.Reservations.Sum(b => b.TotalCost).ToString("N0") ₽</strong></span>
        </div>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id).classList.add('active'); }
    function closeModal(id) { document.getElementById(id).classList.remove('active'); }
    document.querySelectorAll('.modal-overlay').forEach(el => {
        el.addEventListener('click', e => { if (e.target === el) el.classList.remove('active'); });
    });
</script>
