@page "{id}"
@using TennisReservation.Domain.Enums
@using TennisReservation.Presentation.Pages.Reservations
@model TennisReservation.Presentation.Pages.Reservations.EditModel
@{
    ViewData["Title"] = "Редактировать бронирование";
}

<style>
.wrapper {
    max-width: 480px;
    margin: 30px auto;
    background: white;
    padding: 25px;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
}
.form-footer {
    display: flex;
    justify-content: space-between;
    margin-top: 24px;
    gap: 10px;
}

.btn-primary {
    flex: 1;
    justify-content: center;
}

.cost-box {
    text-align: center;
}
</style>

<div class="container" style="padding: 30px 16px;">
    <div class="wrapper">
        <div class="back">
            <a asp-page="./Index"><i class="fas fa-arrow-left"></i> Назад к списку</a>
        </div>

        <div class="page-title">
            <i class="fas fa-edit me-2"></i>Редактировать бронирование
        </div>

        <div asp-validation-summary="ModelOnly" class="alert-error"></div>

        <form method="post">
            <input type="hidden" asp-for="ViewModel.Id" />

            <div class="field">
                <label><i class="fas fa-tennis-ball me-2"></i>Корт</label>
                <select asp-for="ViewModel.TennisCourtId" id="courtSelect">
                    <option value="">— выберите корт —</option>
                    @foreach (var court in Model.TennisCourts)
                    {
                        <option value="@court.Id">@court.Name — @court.HourlyRate ₽/час</option>
                    }
                </select>
                <span asp-validation-for="ViewModel.TennisCourtId" class="text-danger"></span>
            </div>

            <div class="field">
                <label><i class="fas fa-user me-2"></i>Клиент</label>
                <select asp-for="ViewModel.UserId" id="userSelect">
                    <option value="">— выберите клиента —</option>
                    @foreach (var user in Model.Users)
                    {
                        <option value="@user.UserId">@user.LastName @user.FirstName</option>
                    }
                </select>
                <span asp-validation-for="ViewModel.UserId" class="text-danger"></span>
            </div>

            <div class="field">
                <label><i class="fas fa-clock me-2"></i>Начало</label>
                <input asp-for="ViewModel.StartTime" type="datetime-local" id="startTime"
                       value="@Model.ViewModel.StartTime.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="ViewModel.StartTime" class="text-danger"></span>
                <div class="field-hint">Дата и время начала игры</div>
            </div>

            <div class="field">
                <label><i class="fas fa-clock me-2"></i>Окончание</label>
                <input asp-for="ViewModel.EndTime" type="datetime-local" id="endTime"
                       value="@Model.ViewModel.EndTime.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="ViewModel.EndTime" class="text-danger"></span>
                <div class="field-hint">Дата и время окончания игры</div>
            </div>

            <div class="cost-box">
                <div class="label">Предполагаемая стоимость</div>
                <div class="value" id="costValue">—</div>
                <div class="details" id="costDetails">Выберите корт и укажите время</div>
            </div>

            <div class="form-footer">
                <a asp-page="./Index" class="btn btn-outline">
                    <i class="fas fa-arrow-left"></i> Назад
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Сохранить изменения
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const courtPrices = @Html.Raw(Model.CourtPricesJson);
        const courtSelect = document.getElementById('courtSelect');
        const startInput  = document.getElementById('startTime');
        const endInput    = document.getElementById('endTime');
        const costValue   = document.getElementById('costValue');
        const costDetails = document.getElementById('costDetails');

        function calculateCost() {
            const courtId = courtSelect.value;
            const start = new Date(startInput.value);
            const end   = new Date(endInput.value);
            if (!courtId || !startInput.value || !endInput.value) {
                costValue.textContent = '—'; costDetails.textContent = 'Выберите корт и укажите время'; return;
            }
            if (isNaN(start) || isNaN(end) || end <= start) {
                costValue.textContent = '—'; costDetails.textContent = 'Время окончания должно быть позже начала';
                costDetails.style.color = '#c0392b'; return;
            }
            costDetails.style.color = '';
            const hours = (end - start) / 3600000;
            const cost = Math.round(hours * courtPrices[courtId]);
            costValue.classList.add('updating');
            setTimeout(() => { costValue.textContent = cost.toLocaleString('ru-RU') + ' ₽'; costValue.classList.remove('updating'); }, 150);
            costDetails.textContent = `${hours.toFixed(1)} ч × ${courtPrices[courtId]} ₽/час`;
        }

        [courtSelect, startInput, endInput].forEach(el => el.addEventListener('change', calculateCost));
        calculateCost();
    </script>
}
