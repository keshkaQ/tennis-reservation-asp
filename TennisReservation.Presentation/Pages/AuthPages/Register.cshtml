@page
@using TennisReservation.Presentation.Pages.AuthPages
@model TennisReservation.Presentation.Pages.AuthPages.RegisterModel
@{
    ViewData["Title"] = "Регистрация";
}

<style>
.auth-wrapper {
    max-width: 480px;
    margin: 50px auto;
    padding: 0 16px;
}
.auth-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    overflow: hidden;
}
.auth-header {
    background: #1e4b3c;
    color: white;
    padding: 24px;
    text-align: center;
}

.auth-header h4 {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 600;
}

.auth-body {
    padding: 28px;
}

.btn {
    width: 100%;
    padding: 13px;
    margin-bottom: 16px;
    justify-content: center;
}

.auth-footer {
    text-align: center;
    color: #666;
    font-size: 0.9rem;
}

.auth-footer a {
    color: #1e4b3c;
    font-weight: 600
    text-decoration: none;
}

.auth-footer a:hover {
    text-decoration: underline;
}
</style>

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <h4><i class="fas fa-user-plus me-2"></i>Регистрация</h4>
        </div>

        <div class="auth-body">
            @if (Model.ShowRegistrationError && !string.IsNullOrEmpty(Model.RegistrationErrorMessage))
            {
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-circle me-2"></i>@Model.RegistrationErrorMessage
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:12px;"></div>

            <form method="post">
                <div class="field-row">
                    <div class="field">
                        <label asp-for="Input.FirstName">
                            <i class="fas fa-user me-2"></i>Имя
                        </label>
                        <input asp-for="Input.FirstName" placeholder="Введите имя" />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Input.LastName">
                            <i class="fas fa-user me-2"></i>Фамилия
                        </label>
                        <input asp-for="Input.LastName" placeholder="Введите фамилию" />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="field">
                    <label asp-for="Input.Email">
                        <i class="fas fa-envelope me-2"></i>Email
                    </label>
                    <input asp-for="Input.Email" type="email" placeholder="Введите email" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="field">
                    <label asp-for="Input.PhoneNumber">
                        <i class="fas fa-phone me-2"></i>Телефон
                    </label>
                    <input asp-for="Input.PhoneNumber" type="tel" placeholder="+7 (999) 123-45-67" />
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                </div>

                <div class="field-row">
                    <div class="field">
                        <label asp-for="Input.Password">
                            <i class="fas fa-lock me-2"></i>Пароль
                        </label>
                        <input asp-for="Input.Password" type="password" placeholder="Минимум 8 символов" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Input.ConfirmPassword">
                            <i class="fas fa-lock me-2"></i>Подтверждение
                        </label>
                        <input asp-for="Input.ConfirmPassword" type="password" placeholder="Повторите пароль" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-user-plus me-2"></i>Зарегистрироваться
                </button>

                <div class="auth-footer">
                    Уже есть аккаунт?
                    <a asp-page="/AuthPages/Login">Войти</a>
                </div>
            </form>
        </div>
    </div>
</div>
